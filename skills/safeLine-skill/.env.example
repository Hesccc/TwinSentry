# 雷池 WAF 连接配置示例
# 复制此文件为 .env 并填写您的实际配置
# cp .env.example .env

# 雷池管理后台 IP 地址（无需协议前缀和端口）
SAFELINE_HOST=192.168.1.100

# 雷池管理后台端口（默认 9443）
SAFELINE_PORT=9443

# API Bearer Token（在雷池管理后台的 API 设置中获取）
SAFELINE_TOKEN=YOUR_API_TOKEN_HERE

# IP 黑名单组 ID（在雷池管理后台的 IP 黑名单页面中查看）
SAFELINE_GROUP_ID=1

# 白名单 IP 或网段，多个值用逗号隔开，符合条件则直接跳过不予封禁（例如：192.168.1.0/24,10.0.0.1）
SAFELINE_WHITELIST=127.0.0.1,192.168.0.0/16
